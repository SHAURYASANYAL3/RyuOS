# /etc/default/nodm
# nodm configuration file

# Set NODM_ENABLED to something different than 'false' to enable nodm
NODM_ENABLED=true

# User to autologin for
NODM_USER=live

# First vt to try when looking for free VTs
NODM_FIRST_VT=7

# X session to use
NODM_XSESSION=/etc/X11/Xsession

# Options to pass to the X server
NODM_X_OPTIONS='-nolisten tcp'

# Minimum time (in seconds) that a session should last in order for nodm to
# decide that it has not quit too soon.
NODM_MIN_SESSION_TIME=60

# Option to pass to the X server to define the DPI settings
# NODM_X_OPTIONS='-nolisten tcp -dpi 96'
