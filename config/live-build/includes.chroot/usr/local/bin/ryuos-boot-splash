#!/bin/bash
# RyuOS Cyberpunk Boot Splash Animation

MARKER=/var/lib/ryuos/splash-done
[ -f "$MARKER" ] && exit 0

# Show on primary console
if [ -c /dev/tty1 ]; then
    exec >/dev/tty1 2>&1
elif [ -c /dev/console ]; then
    exec >/dev/console 2>&1
fi

clear

C_CYAN="\e[1;36m"
C_BLUE="\e[1;34m"
C_WHITE="\e[1;37m"
C_GRAY="\e[1;30m"
C_RESET="\e[0m"

# Print Centered Logo
echo -e "\n\n\n"
echo -e "${C_CYAN}              ____             ____  _____  ${C_RESET}"
echo -e "${C_CYAN}             / __ \__  ____  _/ __ \/ ___/  ${C_RESET}"
echo -e "${C_BLUE}            / /_/ / / / / / / / / / \__ \   ${C_RESET}"
echo -e "${C_BLUE}           / _, _/ /_/ / /_/ / /_/ /___/ /  ${C_RESET}"
echo -e "${C_CYAN}          /_/ |_|\__, /\__,_/\____//____/   ${C_RESET}"
echo -e "${C_CYAN}                /____/                      ${C_RESET}"
echo -e "                                            "
echo -e "${C_WHITE}                 RyuOS v0.1-cli             ${C_RESET}"
echo -e "\n\n"

# Fake Animation Sequence
frames=(
  "${C_GRAY}[░░░░░░░░░░░░░░░░░░░░]${C_RESET}  0%  Initializing System..."
  "${C_BLUE}[███░░░░░░░░░░░░░░░░░]${C_RESET} 15%  Mounting Rootfs..."
  "${C_CYAN}[███████░░░░░░░░░░░░░]${C_RESET} 35%  Loading Kernel Modules..."
  "${C_CYAN}[███████████░░░░░░░░░]${C_RESET} 55%  Starting Systemd Services..."
  "${C_CYAN}[███████████████░░░░░]${C_RESET} 75%  Configuring Networking..."
  "${C_CYAN}[██████████████████░░]${C_RESET} 90%  Starting Developer Environment..."
  "${C_WHITE}[████████████████████]${C_RESET} 100% System Ready.                "
)

for frame in "${frames[@]}"; do
    echo -ne "\r          $frame"
    sleep 0.3
done

echo -e "\n\n"
sleep 1.0

# Mark as done so it doesn't run again on next boot
mkdir -p /var/lib/ryuos
touch "$MARKER"
clear
