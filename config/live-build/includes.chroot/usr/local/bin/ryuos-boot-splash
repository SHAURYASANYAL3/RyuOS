#!/bin/bash
# RyuOS ASCII boot animation ‚ÄĒ runs once on first boot
MARKER=/var/lib/ryuos/splash-done
[ -f "$MARKER" ] && exit 0

# Show on primary console
if [ -c /dev/tty1 ]; then
    exec >/dev/tty1 2>&1
elif [ -c /dev/console ]; then
    exec >/dev/console 2>&1
fi

CYAN='\033[1;36m'
GREEN='\033[1;32m'
DIM='\033[2m'
RESET='\033[0m'

frame_logo() {
    printf '\033[H\033[J'
    printf '%b' "$CYAN"
    cat << 'EOF'

    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
    ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
    ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
    ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó  ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
    ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
    ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ

EOF
    printf '%b' "$RESET"
}

frame_boot() {
    printf '\033[H\033[J'
    printf '%b' "$GREEN"
    echo ""
    echo "        [=========>          ]  Loading kernel..."
    sleep 0.35
    printf '\033[H\033[J'
    echo ""
    echo "        [=================>  ]  Mounting live filesystem..."
    sleep 0.35
    printf '\033[H\033[J'
    echo ""
    echo "        [====================]  Starting services..."
    sleep 0.35
    printf '%b' "$RESET"
}

frame_welcome() {
    printf '\033[H\033[J'
    printf '%b' "$CYAN"
    cat << 'EOF'

              Welcome to RyuOS
         ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
           Lightweight ¬∑ CLI ¬∑ Fast
           Custom shell: ryush
           System stats: sys-monitor

         Login: live  /  Password: live

EOF
    printf '%b' "$DIM"
    echo "         Boot complete. Starting login..."
    printf '%b' "$RESET"
    sleep 1.2
}

mkdir -p /var/lib/ryuos
frame_logo
sleep 0.5
frame_boot
frame_welcome
touch "$MARKER"
printf '\033[H\033[J'
