#!/bin/bash
# RyuOS Benchmark and Diagnostic Tool

# ANSI Colors
C="\e[1;36m" # Cyan
W="\e[1;37m" # White
G="\e[1;30m" # Gray
R="\e[0m"    # Reset

echo -e "${C}      ____             ____  _____"
echo -e "${C}     / __ \__  ____  _/ __ \/ ___/"
echo -e "${C}    / /_/ / / / / / / / / / \__ \ "
echo -e "${C}   / _, _/ /_/ / /_/ / /_/ /___/ /"
echo -e "${C}  /_/ |_|\__, /\__,_/\____//____/ "
echo -e "${C}        /____/                    ${W}ryu-benchmark v1.0${R}"
echo -e ""

# Boot Time
if command -v systemd-analyze >/dev/null 2>&1; then
    BOOT_TIME=$(systemd-analyze | grep -oP 'Startup finished in \K[^$]+' || echo "N/A")
else
    BOOT_TIME="N/A"
fi
echo -e "${C} > ${W}Boot Time      : ${G}${BOOT_TIME}${R}"

# RAM
MEM_TOTAL=$(free -m | awk '/^Mem:/{print $2}')
MEM_USED=$(free -m | awk '/^Mem:/{print $3}')
echo -e "${C} > ${W}RAM Usage      : ${G}${MEM_USED}MB / ${MEM_TOTAL}MB${R}"

# CPU Load
LOAD_AVG=$(uptime | awk -F'load average:' '{ print $2 }' | xargs)
echo -e "${C} > ${W}Load Average   : ${G}${LOAD_AVG}${R}"

# Processes
PROC_COUNT=$(ps -A --no-headers | wc -l)
echo -e "${C} > ${W}Processes      : ${G}${PROC_COUNT}${R}"

# Packages
PKG_COUNT=$(dpkg -l | grep -c '^ii')
echo -e "${C} > ${W}Packages       : ${G}${PKG_COUNT}${R}"

# Kernel
KERNEL_VER=$(uname -r)
echo -e "${C} > ${W}Kernel         : ${G}${KERNEL_VER}${R}"

# GUI
if [ -n "$DISPLAY" ]; then
    WM=$(wmctrl -m 2>/dev/null | grep Name: | awk '{print $2}' || echo "Openbox")
    echo -e "${C} > ${W}Window Manager : ${G}${WM}${R}"
else
    echo -e "${C} > ${W}Window Manager : ${G}None (CLI)${R}"
fi

echo ""
