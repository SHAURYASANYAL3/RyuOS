#!/bin/bash
# RyuOS benchmark and diagnostic summary.

C="\e[1;36m"
W="\e[1;37m"
G="\e[1;30m"
R="\e[0m"

echo -e "${C}  ____        _   ___  ____"
echo -e " |  _ \\ _   _| | / _ \\/ ___|"
echo -e " | |_) | | | | |/ _ \\\\___ \\"
echo -e " |  _ <| |_| | | (_) |__) |"
echo -e " |_| \\_\\\\__,_|_|\\___/____/${W}  ryu-benchmark v1.1${R}"
echo ""

if command -v systemd-analyze >/dev/null 2>&1; then
    BOOT_TIME=$(systemd-analyze | sed -n 's/^Startup finished in //p' || true)
    SLOW_UNIT=$(systemd-analyze blame 2>/dev/null | head -1 | xargs || true)
else
    BOOT_TIME="N/A"
    SLOW_UNIT="N/A"
fi
echo -e "${C} > ${W}Boot Time      : ${G}${BOOT_TIME:-N/A}${R}"
echo -e "${C} > ${W}Slowest Unit   : ${G}${SLOW_UNIT:-N/A}${R}"

MEM_TOTAL=$(free -m | awk '/^Mem:/{print $2}')
MEM_USED=$(free -m | awk '/^Mem:/{print $3}')
echo -e "${C} > ${W}RAM Usage      : ${G}${MEM_USED}MB / ${MEM_TOTAL}MB${R}"

LOAD_AVG=$(uptime | awk -F'load average:' '{ print $2 }' | xargs)
echo -e "${C} > ${W}Load Average   : ${G}${LOAD_AVG}${R}"

PROC_COUNT=$(ps -A --no-headers | wc -l)
echo -e "${C} > ${W}Processes      : ${G}${PROC_COUNT}${R}"

PKG_COUNT=$(dpkg-query -f '.\n' -W 2>/dev/null | wc -l || echo "N/A")
echo -e "${C} > ${W}Packages       : ${G}${PKG_COUNT}${R}"

echo -e "${C} > ${W}Kernel         : ${G}$(uname -r)${R}"

if [ -n "${DISPLAY:-}" ]; then
    WM=$(wmctrl -m 2>/dev/null | awk '/Name:/{print $2}' || true)
    echo -e "${C} > ${W}Window Manager : ${G}${WM:-Openbox}${R}"
else
    echo -e "${C} > ${W}Window Manager : ${G}None (CLI)${R}"
fi

echo ""
