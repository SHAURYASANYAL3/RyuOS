#!/bin/sh
# Runs last — lock in users/passwords after all other hooks and live-config packages
set -e

echo "[*] Finalizing RyuOS (users, live-config, boot splash)..."

LOGIN_SHELL="/bin/bash"

# --- Live-config: force username at boot (not random) ---
mkdir -p /etc/live/config.conf.d
cat > /etc/live/config.conf.d/ryuos.conf << 'EOF'
# RyuOS live system identity
LIVE_USERNAME="live"
LIVE_USER_FULLNAME="RyuOS User"
LIVE_HOSTNAME="ryuos"
EOF
cat > /etc/live/config.conf.d/ryuos-disable.conf << 'EOF'
LIVE_DISABLE="user-defaults"
EOF

# --- Users (re-apply in case anything earlier overwrote shadow) ---
groupadd -f sudo 2>/dev/null || true
groupadd -f plugdev 2>/dev/null || true
groupadd -f audio 2>/dev/null || true

if ! id live >/dev/null 2>&1; then
    useradd -m -s "$LOGIN_SHELL" -G sudo,audio,plugdev live
fi
mkdir -p /home/live
chown -R live:live /home/live
chmod 755 /home/live

usermod -s "$LOGIN_SHELL" root 2>/dev/null || true
usermod -s "$LOGIN_SHELL" -G sudo,audio,plugdev live 2>/dev/null || true

# Set passwords with chpasswd AND openssl backup (live / root)
echo "live:live" | chpasswd
echo "root:root" | chpasswd
passwd -u live 2>/dev/null || true
passwd -u root 2>/dev/null || true

if command -v openssl >/dev/null 2>&1; then
    LIVE_HASH=$(echo 'live' | openssl passwd -6 -stdin)
    ROOT_HASH=$(echo 'root' | openssl passwd -6 -stdin)
    usermod -p "$LIVE_HASH" live 2>/dev/null || true
    usermod -p "$ROOT_HASH" root 2>/dev/null || true
fi

# PAM: allow login on tty
mkdir -p /etc
cat > /etc/securetty << 'EOF'
console
tty1
tty2
tty3
tty4
tty5
tty6
vc/1
vc/2
EOF

chmod 644 /etc/passwd /etc/group
chmod 640 /etc/shadow /etc/gshadow 2>/dev/null || true
chown root:shadow /etc/shadow /etc/gshadow 2>/dev/null || true

# --- Enable boot splash + login fix (symlinks; no systemctl in chroot) ---
mkdir -p /etc/systemd/system/multi-user.target.wants
for unit in ryuos-splash.service ryuos-fix-login.service; do
    if [ -f "/etc/systemd/system/$unit" ]; then
        ln -sf "/etc/systemd/system/$unit" \
            "/etc/systemd/system/multi-user.target.wants/$unit"
    fi
done
chmod 755 /usr/local/bin/ryuos-boot-splash /usr/local/bin/ryuos-fix-login 2>/dev/null || true

# Login banner (shown before password prompt)
cat > /etc/issue << 'ISSUE'
[1;36m
  ____        _   ___  ____
 |  _ \ _   _| | / _ \/ ___|
 | |_) | | | | |/ _ \\___ \
 |  _ <| |_| | | (_) |__) |
 |_| \\_\\__,_|_|\\___/____/
[0m
       RyuOS v0.1-cli — Debian 12 base

  Login:  live   Password: live
          root   Password: root

  (If live fails, try password: just press Enter)

ISSUE

echo "[+] Finalize done. Users: $(grep -E '^(live|root):' /etc/passwd || true)"
