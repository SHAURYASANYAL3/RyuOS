#!/bin/sh
set -e

echo "[*] Installing custom fastfetch for RyuOS branding..."

# Download and extract fastfetch
cd /tmp
wget -q https://github.com/fastfetch-cli/fastfetch/releases/latest/download/fastfetch-linux-amd64.tar.gz
tar -xzf fastfetch-linux-amd64.tar.gz

# Find the extracted fastfetch binary and copy it
find . -name "fastfetch" -type f -exec cp {} /usr/local/bin/ \;
chmod +x /usr/local/bin/fastfetch

# Clean up
rm -rf /tmp/fastfetch*

echo "[+] fastfetch installed."
